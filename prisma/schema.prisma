// ─────────────────────────────────────────────────────────────────────────
// Docket — Prisma schema
// Mirrors src/types.ts so server.ts (the Express routes) never has to change.
// JSON columns are used for fields that are still evolving on the frontend
// (theme, dashboardWidgets, customFieldValues, calls/meetings/tasks on Client,
// etc.) — you can add new keys to these from the UI any time with ZERO
// migrations. Promote a JSON field to its own table later only if you need
// to query/filter across rows (e.g. "all invoices across all clients").
// ─────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────

enum UserRole {
  SUPERADMIN
  ADMIN
  LAWYER
  PARALEGAL
  SECRETARY
}

enum CaseStatus {
  ACTIVE
  ON_HOLD
  CLOSED
}

enum ClientUpdateStatus {
  DRAFT
  APPROVED
  SENT
  FAILED
}

// ─── TENANCY ────────────────────────────────────────────────────────────

model Company {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  setupComplete Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  settings      CompanySettings?
  users         User[]
  clients       Client[]
  cases         Case[]
  caseEvents    CaseEvent[]
  deadlines     Deadline[]
  clientUpdates ClientUpdate[]
  templates     DocumentTemplate[]
  documents     GeneratedDocument[]
  chatMessages  ChatMessage[]
  consentLogs   ConsentLog[]
  featureFlags  FeatureFlag[]
  announcements CompanyAnnouncement[]
  invitations   Invitation[]
  accessUpdates AccessUpdateRequest[]
  feedbacks     PlatformFeedback[]
  feeNotes      FeeNote[]
  disbursements Disbursement[]
  invoices      Invoice[]
  files         CaseFile[]
  dispatchLogs  ClientDispatchLog[]
  teamMembers   CaseTeamMember[]
  diaryEntries  CaseDiaryEntry[]
  correspondenceSnippets  CorrespondenceSnippet[]
  correspondenceTemplates CorrespondenceTemplate[]
  whatsappConfig          WhatsAppConfig?
  whatsappTemplates       WhatsAppTemplate[]
  emailChannelConfig      EmailChannelConfig?
  smsChannelConfig        SmsChannelConfig?
  domainVerification      DomainVerification?
  clauses                 Clause[]
  courtBundles            CourtBundle[]
  signatureRequests       SignatureRequest[]
  legalNotices            LegalNotice[]
  chatPreferences         UserChatPreference[]
  chatGroups              ChatGroup[]
  workflows               WorkflowAutomation[]
}

model CompanySettings {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  firmName          String?
  prismaoffices     Json?
  offices           Json?
  bankAccounts      Json?
  caseTypes         Json     @default("[]")
  courts            Json     @default("[]")
  referenceFormat   String?
  address           String?
  phone             String?
  email             String?
  theme             Json     @default("{}")
  navigation        Json     @default("{}")
  reminderDefaults  Json     @default("{}")
  updatePreferences Json     @default("{}")
  branding          Json     @default("{}")
  communicationStyle Json    @default("{}")
  activeChannels    Json     @default("{}")
  calendarIntegration Json?
  caseStages        Json     @default("[]")
  dashboardWidgets  Json     @default("[]")
  firmAnnouncement  Json?
  dashboardConfig   Json?
  terminology       Json?
  customFields      Json?
  customSections    Json?
  correspondenceSlaHours Int? @default(4)

  updatedAt DateTime @updatedAt
}

// ─── USERS ──────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fullName     String
  email        String   @unique
  avatarUrl    String?
  tagline      String?
  role         UserRole @default(LAWYER)
  isActive     Boolean  @default(true)
  isSuperAdmin Boolean  @default(false)
  allowedPages Json?

  // Stored as JSON; encrypt the token values at the application layer
  // (AES-256-GCM) before writing — see security notes.
  googleCalendar Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedCases        Case[]         @relation("AssignedLawyer")
  createdCaseEvents    CaseEvent[]
  draftedClientUpdates ClientUpdate[]
  chatMessages         ChatMessage[]
  clauses              Clause[]

  @@index([companyId])
}

// ─── CLIENTS ────────────────────────────────────────────────────────────

model Client {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fullName      String
  idNumber      String?
  phone         String?
  email         String?
  address       String?
  occupation    String?
  organisation  String?
  notes         String?
  customFieldValues Json?

  photo                  String?
  dateOfFirstEngagement  DateTime?
  clientSource           String?
  referredById           String?
  clientCategory         String?
  riskRating             String?
  valueTier              String?
  isVip                  Boolean?  @default(false)
  conflictCheck          String?
  conflictNotes          String?
  nextAction             String?
  nextActionDue          DateTime?
  nextActionAssignedTo   String?
  preferredMeeting       String?
  accessibilityNeeds     String?
  doNotContactPeriods    Json?
  optOutChannels         Json?
  internalTags           Json?
  segments               Json?
  feeArrangement         String?
  billingRate            Float?
  paymentTerms           String?
  retainerAmount         Float?
  retainerBalance        Float?
  trustBalance           Float?
  outstandingBalance     Float?

  onboardingComplete     Boolean? @default(false)
  onboardingChecklist    Json?
  kycStatus              String?
  kycDocuments           Json?
  engagementLetterStatus String?
  termsAccepted          Boolean? @default(false)
  termsAcceptedAt        DateTime?
  retentionPolicy        String?
  retentionOverrideReason String?

  // Flexible JSON blocks — frontend can keep evolving these freely
  calls             Json?
  meetings          Json?
  tasks             Json?
  followUps         Json?
  relationships     Json?
  invoices          Json?
  consents          Json?
  documentRequests  Json?
  secureUploadLinks Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cases         Case[]
  clientUpdates ClientUpdate[]

  @@index([companyId])
}

// ─── CASES ──────────────────────────────────────────────────────────────

model Case {
  id               String     @id @default(cuid())
  companyId        String
  company          Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId         String
  client           Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  referenceNumber  String?
  caseType         String?
  court            String?
  opposingParty    String?
  assignedLawyerId String?
  assignedLawyer   User?      @relation("AssignedLawyer", fields: [assignedLawyerId], references: [id])
  currentStage     String?
  status           CaseStatus @default(ACTIVE)
  openedDate       DateTime
  notes            String?
  customFieldValues Json?

  priority             String?
  caseValue            Float?
  budget               Float?
  flags                Json?
  tags                 Json?
  statuteOfLimitations DateTime?
  observers            Json?
  outcome              String?
  outcomeNotes         String?
  closedDate           DateTime?
  isLegalHold          Boolean? @default(false)
  isArchived           Boolean? @default(false)
  riskLevel            String?
  riskFactors          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events        CaseEvent[]
  deadlines     Deadline[]
  clientUpdates ClientUpdate[]
  documents     GeneratedDocument[]
  chatMessages  ChatMessage[]
  feeNotes      FeeNote[]
  disbursements Disbursement[]
  invoices      Invoice[]
  files         CaseFile[]
  dispatchLogs  ClientDispatchLog[]
  teamMembers   CaseTeamMember[]
  diaryEntries  CaseDiaryEntry[]
  courtBundles  CourtBundle[]
  signatureRequests SignatureRequest[]

  @@index([companyId])
  @@index([clientId])
}

// ─── CASE FILES (R2 OBJECT STORAGE) ──────────────────────────────────────

model CaseFile {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  storageKey  String   @unique // path inside the R2 bucket: companyId/caseId/uuid-filename
  fileName    String
  fileSize    Int
  mimeType    String
  uploadedById String?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([caseId])
}

model CaseEvent {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  eventType   String?
  title       String
  description String?
  eventDate   DateTime?
  relatedDeadlineId String?
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([caseId])
}

// ─── DEADLINES ──────────────────────────────────────────────────────────

model Deadline {
  id                    String   @id @default(cuid())
  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  caseId                String
  case                  Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title                 String
  deadlineType          String?
  dueDate               DateTime
  remindDaysBefore      Json     @default("[]")
  notifyAll             Boolean  @default(false)
  isResolved            Boolean  @default(false)
  remindersSent         Json     @default("[]")
  googleCalendarEventId String?
  customFieldValues     Json?

  // Previously missing — priority and notes were being sent by the frontend
  // on every create/update and silently dropped by Prisma. Added here.
  priority           String?
  notes              String?

  // Court appearance detail fields
  courtroom          String?
  presidingJudge     String?

  // Missed-deadline compliance record (Section 5 "Missed Log" wizard)
  isMissedFlag       Boolean?  @default(false)
  missedReason       String?
  missedNotes        String?
  supervisorNotified Boolean?  @default(false)
  missedLoggedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([caseId])
}

// ─── CLIENT UPDATES ─────────────────────────────────────────────────────

model ClientUpdate {
  id          String             @id @default(cuid())
  companyId   String
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  caseId      String
  case        Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  draftedById String?
  draftedBy   User?              @relation(fields: [draftedById], references: [id])
  message     String
  status      ClientUpdateStatus @default(DRAFT)
  channelsSent Json              @default("{}")
  sentAt      DateTime?

  // Approval workflow
  submittedForApprovalAt DateTime?
  submittedById          String?
  approvedById           String?
  approvedAt             DateTime?
  rejectionReason        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

// ─── DOCUMENTS ──────────────────────────────────────────────────────────

model DocumentTemplate {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  templateContent String
  variables   Json     @default("[]")
  structure   Json?
  usageCount  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  generatedDocuments GeneratedDocument[]

  @@index([companyId])
}

model GeneratedDocument {
  id            String            @id @default(cuid())
  companyId     String
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  caseId        String
  case          Case              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  templateId    String?
  template      DocumentTemplate? @relation(fields: [templateId], references: [id])
  generatedById String?
  content       String
  fileUrl       String?
  approvalStatus  String            @default("Pending")
  approvedById    String?
  approvedAt      DateTime?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([caseId])
}

// ─── CORRESPONDENCE SNIPPETS & TEMPLATES (Updates page) ──────────────────

model CorrespondenceSnippet {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title        String
  category     String
  richContent  String
  variables    Json     @default("[]")
  isFirmWide   Boolean  @default(true)
  createdById  String?
  usageCount   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model CorrespondenceTemplate {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  category     String
  matterType   String?
  eventType    String?
  richContent  String
  variables    Json     @default("[]")
  disclaimers  Json     @default("[]")
  isDefault    Boolean  @default(false)
  isFirmWide   Boolean  @default(true)
  createdById  String?
  usageCount   Int      @default(0)
  lastUsedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

// ─── BILLING: FEE NOTES, DISBURSEMENTS, INVOICES ────────────────────────

model FeeNote {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  date        DateTime
  lawyerName  String
  description String
  hours       Float
  rate        Float
  status      String   @default("unbilled")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([caseId])
}

model Disbursement {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  date        DateTime
  description String
  amount      Float
  paidBy      String
  status      String   @default("unbilled")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([caseId])
}

model Invoice {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  caseId        String
  case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  invoiceNumber String
  invoiceDate   DateTime
  dueDate       DateTime
  lineItems     Json
  subtotal      Float
  discount      Float    @default(0)
  tax           Float    @default(0)
  total         Float
  status        String   @default("pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([caseId])
}

// ─── CHAT ───────────────────────────────────────────────────────────────

model ChatMessage {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  caseId       String?
  case         Case?    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sentById     String
  sentBy       User     @relation(fields: [sentById], references: [id])
  message      String
  fileUrl      String?
  readBy       Json     @default("[]")

  isOnRecord   Boolean   @default(false)
  onRecordAt   DateTime?
  onRecordById String?
  editedAt     DateTime?
  editHistory  Json?
  deletedAt    DateTime?
  isDeleted    Boolean   @default(false)
  reactions    Json?
  replyToId    String?
  isPinned     Boolean   @default(false)
  attachments  Json?
  mentions     Json?
  references   Json?
  dmRoomId     String?

  createdAt DateTime @default(now())
  userStates   ChatMessageUserState[]

  @@index([companyId])
  @@index([caseId])
  @@index([dmRoomId])
}

model ChatMessageUserState {
  id            String   @id @default(cuid())
  messageId     String
  message       ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId        String
  isDeletedForMe Boolean @default(false)
  isStarred     Boolean  @default(false)
  isPinnedByMe  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([messageId, userId])
  @@index([userId])
  @@index([messageId])
}

// ─── CONSENT / FLAGS / ANNOUNCEMENTS ────────────────────────────────────

model ConsentLog {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId      String?
  action      String
  consented   Boolean
  consentedAt DateTime @default(now())

  @@index([companyId])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  featureName String
  isEnabled   Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  @@unique([companyId, featureName])
}

model CompanyAnnouncement {
  id          String    @id @default(cuid())
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title       String
  body        String
  isActive    Boolean   @default(true)
  isDismissed Boolean   @default(false)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
}

// ─── INVITES / ACCESS REQUESTS / REGISTRATION ──────────────────────────

model Invitation {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email       String
  role        String
  name        String?
  allowedPages Json?
  tokenHash   String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([companyId])
}

model AccessUpdateRequest {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId      String
  proposedAllowedPages Json?
  tokenHash   String    @unique
  expiresAt   DateTime
  appliedAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([companyId])
}

model RegistrationRequest {
  id             String   @id @default(cuid())
  firmName       String
  registrantName String
  email          String
  country        String
  firmSize       String
  referralSource String?
  riskScore      String
  status         String   @default("needs_review")
  companyId      String?
  inviteToken    String?
  createdAt      DateTime @default(now())
}

model PlatformFeedback {
  id          String   @id @default(cuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  userId      String?
  type        String
  message     String
  isRead      Boolean  @default(false)
  submittedAt DateTime @default(now())
}

// ─── PLATFORM / SUPERADMIN (shared schema — superadmin backend plugs in here) ──

model AuditLog {
  id              String   @id @default(cuid())
  action          String
  ip              String
  detail          String
  endpoint        String?
  method          String?
  targetCompanyId String?
  targetUserId    String?
  result          String?
  timestamp       DateTime @default(now())

  @@index([action])
  @@index([timestamp])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  ip        String
  success   Boolean
  timestamp DateTime @default(now())

  @@index([ip, timestamp])
}

// ─── NEW CASE-RELATED PERSISTED MODELS ─────────────────────────────────────

model ClientDispatchLog {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorId  String?
  type      String
  text      String

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([caseId])
}

model CaseTeamMember {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  caseId        String
  case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId        String
  roleOnMatter  String
  contribution  String?
  assignedAt    DateTime @default(now())

  @@index([companyId])
  @@index([caseId])
  @@unique([caseId, userId])
}

model CaseDiaryEntry {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  caseId        String
  case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorName    String
  category      String
  text          String
  isPinned      Boolean  @default(false)
  reviewStatus  String   @default("Pending")
  hours         Float    @default(0)
  color         String   @default("indigo")
  entryDate     DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([companyId])
  @@index([caseId])
}

// Singleton row (id always "singleton") — replaces the two loose fields
// that lived at the root of db.json (activeSuperadminSessionId, platformLocked)
model PlatformState {
  id                        String  @id @default("singleton")
  activeSuperadminSessionId String?
  platformLocked            Boolean @default(false)
}

// ─── WHATSAPP BUSINESS INTEGRATION (real Meta Cloud API) ─────────────────

model WhatsAppConfig {
  id                    String    @id @default(cuid())
  companyId             String    @unique
  company               Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  phoneNumberId         String
  businessAccountId     String
  accessTokenEncrypted  String    // AES-256-GCM ciphertext — never store the raw token
  accessTokenIv         String
  accessTokenAuthTag    String
  displayPhoneNumber    String?
  verifiedBusinessName  String?
  isVerified            Boolean   @default(false)
  lastVerifiedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WhatsAppTemplate {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  metaTemplateId   String?   // set once Meta accepts submission
  name             String
  category         String    // Meta's real categories: MARKETING | UTILITY | AUTHENTICATION
  language         String    @default("en_US")
  bodyText         String
  headerText       String?
  footerText       String?
  status           String    @default("pending") // pending | approved | rejected | submission_failed
  rejectionReason  String?
  submittedAt      DateTime?
  lastSyncedAt     DateTime?
  createdById      String?
  usageCount       Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@unique([companyId, name, language])
}

model EmailChannelConfig {
  id                  String   @id @default(cuid())
  companyId           String   @unique
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  smtpHost            String
  smtpPort            Int
  smtpUser            String
  smtpPassEncrypted   String
  smtpPassIv          String
  smtpPassAuthTag     String
  fromEmail           String?
  fromName            String?
  isVerified          Boolean  @default(false)
  lastVerifiedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SmsChannelConfig {
  id                    String   @id @default(cuid())
  companyId             String   @unique
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  twilioAccountSid      String
  twilioAuthTokenEncrypted String
  twilioAuthTokenIv     String
  twilioAuthTokenAuthTag String
  fromPhoneNumber       String
  isVerified            Boolean  @default(false)
  lastVerifiedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DomainVerification {
  id                String    @id @default(cuid())
  companyId         String    @unique
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  domain            String
  dkimSelector      String?
  spfVerified       Boolean   @default(false)
  spfRecord         String?
  dkimVerified      Boolean   @default(false)
  dkimRecord        String?
  dmarcVerified     Boolean   @default(false)
  dmarcRecord       String?
  dmarcPolicy       String?
  lastCheckedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Clause {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title        String
  category     String
  matterType   String
  jurisdiction String
  content      String
  usageCount   Int       @default(0)
  createdById  String?
  createdBy    User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model CourtBundle {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  caseId        String
  case          Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title         String
  court         String
  status        String    @default("Draft") // Draft, Final, Submitted
  version       Int       @default(1)
  storageKey    String?   // path inside the R2 bucket for the merged PDF
  documentOrder Json      // Ordered list of { type: 'file'|'generated', id, dividerLabel? }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([caseId])
}

model SignatureRequest {
  id            String      @id @default(cuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  caseId        String
  case          Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  documentId    String?     // Can target GeneratedDocument or CaseFile
  documentType  String      // "generated" | "file"
  title         String
  signingOrder  String      // "parallel" | "sequential"
  status        String      @default("Pending") // Pending, Completed, Expired, Void
  expiresAt     DateTime?
  documentHash  String      // Real SHA-256 hash of the document bytes/text
  
  signatories   Signatory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([caseId])
}

model Signatory {
  id                 String           @id @default(cuid())
  signatureRequestId String
  signatureRequest   SignatureRequest @relation(fields: [signatureRequestId], references: [id], onDelete: Cascade)
  name               String
  email              String
  role               String           // e.g. lessee, witness, litigant
  status             String           @default("Pending") // Pending, Signed
  signedAt           DateTime?
  otpCodeHash        String?          // short-lived OTP hash
  otpExpiresAt       DateTime?
  signatureTypedText String?
  ipAddress          String?
  userAgent          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([signatureRequestId])
}

// ─── LEGAL NOTICES & USER CHAT PREFERENCES ───────────────────────────────

model LegalNotice {
  id                   String               @id @default(cuid())
  companyId            String
  company              Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById          String?
  title                String
  content              String
  requiresAllSignature Boolean              @default(false)
  isActive             Boolean              @default(true)
  acknowledgements     LegalNoticeAck[]

  createdAt DateTime @default(now())

  @@index([companyId])
}

model LegalNoticeAck {
  id             String      @id @default(cuid())
  noticeId       String
  notice         LegalNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  userId         String
  acknowledgedAt DateTime    @default(now())

  @@unique([noticeId, userId])
  @@index([noticeId])
}

model UserChatPreference {
  id          String   @id @default(cuid())
  userId      String
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  keywordRules Json    @default("[]")
  folders      Json    @default("[]")
  chatTheme    String?  @default("default")
  chatFontSize String?  @default("base")
  compactMode  Boolean? @default(false)
  bubbleColor  String?  @default("default")
  chatBgUrl    String?  @default("")
  chatBgColor  String?  @default("default")

  updatedAt DateTime @updatedAt

  @@unique([userId, companyId])
  @@index([companyId])
}

model ChatGroup {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  logoUrl     String?
  adminId     String   // Creator of the group
  memberIds   Json     // array of user IDs
  chatTheme   String?  @default("default")
  chatBgUrl   String?  @default("")
  chatBgColor String?  @default("default")
  bubbleColor String?  @default("default")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

model WorkflowAutomation {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  trigger     String
  condition   String?
  actions     Json
  isActive    Boolean  @default(true)
  runCount    Int      @default(0)
  successRate Float    @default(100)
  lastRun     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([companyId])
}

