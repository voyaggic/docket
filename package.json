{
  "name": "docket-app",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node -e \"try { require('dotenv').config(); } catch(e) {} const hasDb = process.env.DATABASE_URL && !process.env.DATABASE_URL.includes('//postgres:postgres@localhost:5432/'); if (hasDb) { try { require('child_process').execSync('npx prisma db push --accept-data-loss', {stdio: 'inherit'}); } catch(e) { console.error('Prisma db push failed:', e.message); } }\" && node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1076.0",
    "@aws-sdk/s3-request-presigner": "^3.1076.0",
    "@google/genai": "^2.4.0",
    "@prisma/client": "^6.1.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express-session": "^1.19.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@vitejs/plugin-react": "^5.0.4",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "googleapis": "^173.0.0",
    "lucide-react": "^0.546.0",
    "memorystore": "^1.6.8",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.11",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "resend": "^6.14.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "prisma": "^6.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
